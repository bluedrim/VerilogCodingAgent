# Default Ollama model path
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3
LLM_TEMPERATURE=0.1
# ARTIFACT_DIR=generated_rtl

# OpenAI current account API key
# Create/use an API key from your OpenAI account and set it here.
# LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4.1
# OPENAI_API_KEY=replace_with_your_openai_api_key

# gpt-oss through Ollama
# LLM_PROVIDER=gpt-oss
# GPT_OSS_MODEL=gpt-oss:20b
# OLLAMA_BASE_URL=http://localhost:11434

# gpt-oss through an OpenAI-compatible chat/completions endpoint
# LLM_PROVIDER=gpt-oss
# GPT_OSS_MODEL=gpt-oss
# GPT_OSS_API_URL=http://abc.net:30001/chat/completions
# GPT_OSS_API_KEY=replace_with_your_key
