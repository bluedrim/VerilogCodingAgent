# Default Ollama model path
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192
# LLM_TIMEOUT_SECONDS=180
# ARTIFACT_DIR=generated_rtl

# Retry defaults for CLI and dashboard runs
MAX_RETRIES=3
# MAX_MANAGER_RETRIES=3
# MAX_ARCHITECTURE_RETRIES=3
# MAX_SUPERVISOR_RETRIES=3
# MAX_CONTROL_DATAPATH_RETRIES=3
# MAX_TESTBENCH_RETRIES=3

# OpenAI current account API key
# Create/use an API key from your OpenAI account and set it here.
# LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4.1
# OPENAI_API_KEY=replace_with_your_openai_api_key

# gpt-oss through Ollama
# LLM_PROVIDER=gpt-oss
# GPT_OSS_MODEL=gpt-oss:20b
# OLLAMA_BASE_URL=http://localhost:11434

# gpt-oss through an OpenAI-compatible chat/completions endpoint
# LLM_PROVIDER=gpt-oss
# GPT_OSS_MODEL=gpt-oss
# GPT_OSS_API_URL=http://abc.net:30001/chat/completions
# GPT_OSS_API_KEY=replace_with_your_key

# Dashboard launch defaults
# The dashboard UI only asks for requirement input and LLM provider.
# Other launch behavior is controlled here.
# DASHBOARD_AUTO_APPROVE=true
# DASHBOARD_NO_TESTBENCH=false
# DASHBOARD_REQUIRE_LINT=false
# DASHBOARD_RUN_SIMULATION=false
# RUN_SIMULATION=false
# DASHBOARD_MAX_RETRIES=3
# DASHBOARD_MAX_MANAGER_RETRIES=3
# DASHBOARD_MAX_ARCHITECTURE_RETRIES=3
# DASHBOARD_MAX_SUPERVISOR_RETRIES=3
# DASHBOARD_MAX_CONTROL_DATAPATH_RETRIES=3
# DASHBOARD_MAX_TESTBENCH_RETRIES=3
# DASHBOARD_MAX_MANAGER_TASKS=32
